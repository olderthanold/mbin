# Shell scripts must stay LF (Linux-safe)
*.sh text eol=lf

# Windows command scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Common source/docs as LF
*.py   text eol=lf
*.js   text eol=lf
*.ts   text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.md   text eol=lf

# Binary files (never normalize)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.pdf  binary
*.zip  binary
*.7z   binary
*.xlsm binary